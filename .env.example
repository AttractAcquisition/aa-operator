# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Anthropic API ────────────────────────────────────────────────────────────
# Used by Supabase Edge Functions (server-side only — NEVER expose in frontend)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Meta Ads API ─────────────────────────────────────────────────────────────
# Get from: https://developers.facebook.com → Your App → Marketing API
META_ACCESS_TOKEN=your-meta-access-token
META_AD_ACCOUNT_ID=act_your-ad-account-id

# ─── WhatsApp Business API ────────────────────────────────────────────────────
# Get from: https://developers.facebook.com → Your App → WhatsApp
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-key-here
RESEND_FROM_EMAIL=notifications@yourdomain.com
